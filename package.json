{
  "name": "peerpay-store",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "bun --watch run server/index.ts",
    "start": "bun run server/index.ts",
    "build": "bun build --target=bun --production --root . --outdir=dist ./server/index.ts",
    "build:bin": "bun build --compile --target=bun-linux-x64 --production --outfile=dist/peerpay-store ./server/index.ts",
    "publish": "bun run scripts/publish.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "antd:lint": "antd lint src/client --format json"
  },
  "dependencies": {
    "@ant-design/icons": "latest",
    "antd": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@ant-design/cli": "latest",
    "@types/bun": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
